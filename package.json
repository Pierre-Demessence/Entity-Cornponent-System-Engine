{
  "name": "@pierre/ecs",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Project-agnostic Entity-Component-System primitives (stores, queries, spatial index, templates, scheduler, event bus).",
  "license": "MIT",
  "sideEffects": false,
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./world": "./src/world.ts",
    "./component-store": "./src/component-store.ts",
    "./spatial": "./src/spatial.ts",
    "./query": "./src/query.ts",
    "./template": "./src/template.ts",
    "./event-bus": "./src/event-bus.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./scheduler": "./src/scheduler.ts",
    "./tick-source": "./src/tick-source.ts",
    "./tick-runner": "./src/tick-runner.ts",
    "./entity-id": "./src/entity-id.ts",
    "./validation": "./src/validation.ts",
    "./test-utils": "./src/test-utils.ts",
    "./modules/*": "./src/modules/*/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts"
}
